{
  "nodeId": "coding.review",
  "packId": "coding",
  "contractVersion": "v1alpha1",
  "intent": "Review the current implementation delta for correctness, maintainability, and rework needs.",
  "inputArtifactRoles": [
    "implementation-delta"
  ],
  "outputArtifactRoles": [
    "review-record"
  ],
  "allowedTransitions": [
    "coding.verify",
    "coding.implement"
  ],
  "humanConfirmationRequired": true,
  "parallelizable": false,
  "evidenceRequirements": [
    "review-verdict"
  ],
  "policyRefs": [
    "policies/authoring-review.md",
    "policies/implementation-safety.md"
  ]
}
